generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        Int      @id @default(autoincrement())
  title     String
  desc      String
  image     String
  gallery   String[] @default([])
  link      String?
  github    String?
  tech      String[]
  createdAt DateTime @default(now())
}

model Experience {
  id        Int      @id @default(autoincrement())
  role      String
  company   String
  location  String?
  startDate String
  endDate   String
  desc      String
  skills    String[] @default([])
  link      String?
  gallery   String[] @default([])
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Visitor {
  id        Int      @id @default(autoincrement())
  name      String
  role      String   @default("Orang biasa")
  target    String   @default("Website keseluruhan")
  createdAt DateTime @default(now())
}
